# Copy this file to `.env` inside Backend/ and fill in real values.
# Never commit the actual .env file.

# --- App ---
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=replace-with-a-long-random-string

# --- Database (once you add one) ---
DATABASE_URL=postgresql://user:password@localhost:5432/finsight

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Market data API (once integrated) ---
MARKET_DATA_API_KEY=your-api-key-here

# --- Auth (once implemented) ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY_MINUTES=60
